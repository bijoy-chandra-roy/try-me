# Include the database name in the path (e.g. /tryme). Without it, MongoDB uses "test".
MONGODB_URI=mongodb://localhost:27017/tryme
USE_IN_MEMORY_DB=true
# Optional. If missing or rejected by ImgBB, uploads fall back to Freeimage.host.
IMGBB_API_KEY=your_imgbb_api_key
HF_TOKEN=your_hugging_face_token
VTO_API_URL=https://yisol-idm-vton.hf.space/call/tryon
VTO_TIMEOUT_MS=300000
# Public site origin (no trailing slash). Required for production deploy + redeploy after changing.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
AUTH_SECRET=generate-a-random-secret-with-openssl-rand-base64-32
# Optional on Vercel (Auth.js auto-detects the host). Do NOT set to localhost in production.
# AUTH_URL=https://your-app.vercel.app
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
